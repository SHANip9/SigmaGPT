# ========================
# SigmaGPT - Environment Variables
# ========================
# Copy this file to .env and fill in your actual values

# MongoDB Connection URI (local or Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sigmagpt?retryWrites=true&w=majority

# OpenAI API Key (get yours from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-api-key-here

# Server Port (optional, defaults to 8080)
PORT=8080

# JWT Secret for authentication tokens (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL for CORS (set to your Vercel frontend URL in production)
FRONTEND_URL=http://localhost:5173
